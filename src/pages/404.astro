---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page not found — Mama Jiggles"
  description="That page wobbled away. Head back to mamajiggles.com."
>
  <main class="not-found">
    <div class="not-found__inner">
      <div class="not-found__stars" aria-hidden="true">★ ★ ★</div>

      <p class="not-found__code">404</p>

      <h1 class="not-found__title">
        That one wobbled away.
      </h1>

      <p class="not-found__copy">
        We can't find the page you're looking for. Maybe it slipped off
        the tray. Head back home and pick a flavor.
      </p>

      <a href="/" class="btn-primary not-found__btn">Take Me Home</a>

      <p class="not-found__sub">or scan the QR code on Mama's card again</p>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .not-found__inner {
    max-width: 32rem;
  }
  .not-found__stars {
    color: var(--color-red);
    letter-spacing: 0.5rem;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }
  .not-found__code {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 9rem);
    color: var(--color-red);
    line-height: 1;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }
  .not-found__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    color: var(--color-navy);
    margin: 0 0 1rem;
    text-transform: uppercase;
    line-height: 1.1;
  }
  .not-found__copy {
    color: var(--color-ink);
    font-size: 1.05rem;
    line-height: 1.5;
    margin: 0 0 2rem;
  }
  .not-found__btn {
    margin-bottom: 1.5rem;
  }
  .not-found__sub {
    font-family: var(--font-script);
    color: var(--color-navy);
    opacity: 0.7;
    font-size: 0.85rem;
    margin: 0;
    letter-spacing: 0.04em;
  }
</style>
