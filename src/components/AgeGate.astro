---
// Age gate modal — appears on first visit, dismissable via localStorage.
// Server-renders hidden; client script reveals if no flag is set.
---

<div id="age-gate" class="age-gate" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="age-gate-title">
  <div class="age-gate__backdrop"></div>
  <div class="age-gate__card">
    <div class="age-gate__stars" aria-hidden="true">★ ★ ★</div>
    <h2 id="age-gate-title" class="age-gate__title">Hold up, sugar.</h2>
    <p class="age-gate__copy">
      You gotta be <strong>21 or older</strong> to step inside.
      <br />
      Are you of legal drinking age?
    </p>
    <div class="age-gate__buttons">
      <button type="button" class="btn-primary" id="age-gate-yes">Yes, I'm 21+</button>
      <button type="button" class="btn-secondary" id="age-gate-no">No, take me back</button>
    </div>
    <p class="age-gate__fine">Please drink responsibly.</p>
  </div>
</div>

<style>
  .age-gate {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .age-gate[hidden] {
    display: none;
  }
  .age-gate__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 25, 47, 0.85);
    backdrop-filter: blur(4px);
  }
  .age-gate__card {
    position: relative;
    background: var(--color-cream);
    border: 4px solid var(--color-navy);
    box-shadow: 8px 8px 0 var(--color-red);
    max-width: 28rem;
    width: 100%;
    padding: 2.5rem 1.75rem;
    text-align: center;
  }
  .age-gate__stars {
    color: var(--color-red);
    letter-spacing: 0.5rem;
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .age-gate__title {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-navy);
    margin: 0 0 0.75rem;
  }
  .age-gate__copy {
    color: var(--color-ink);
    font-size: 1.05rem;
    margin: 0 0 1.5rem;
    line-height: 1.45;
  }
  .age-gate__buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .age-gate__fine {
    margin: 1.25rem 0 0;
    font-size: 0.8rem;
    color: var(--color-navy);
    opacity: 0.7;
    font-family: var(--font-script);
    letter-spacing: 0.05em;
  }
  @media (min-width: 480px) {
    .age-gate__buttons {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>

<script is:inline>
  (function () {
    const STORAGE_KEY = "mj_age_verified";
    const gate = document.getElementById("age-gate");
    if (!gate) return;

    const verified = (() => {
      try { return localStorage.getItem(STORAGE_KEY) === "yes"; }
      catch { return false; }
    })();

    if (!verified) {
      gate.hidden = false;
      gate.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    document.getElementById("age-gate-yes")?.addEventListener("click", () => {
      try { localStorage.setItem(STORAGE_KEY, "yes"); } catch {}
      gate.hidden = true;
      gate.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    });

    document.getElementById("age-gate-no")?.addEventListener("click", () => {
      window.location.href = "https://www.google.com";
    });
  })();
</script>
